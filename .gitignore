!outputs/figures/final_pr_auc_comparison.png
!outputs/figures/final_precision_at_k_comparison.png
!outputs/figures/final_recall_at_k_comparison.png
!outputs/figures/final_cpu_gpu_training_time_comparison.png

# Keep final summary metrics for GitHub presentation.
# Ignore intermediate metrics by default.
outputs/metrics/*
!outputs/metrics/.gitkeep
!outputs/metrics/final_model_comparison.csv
!outputs/metrics/final_model_improvement_summary.csv
